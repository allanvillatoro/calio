# Site Configuration
NEXT_PUBLIC_SITE_URL=https://caliojoyeria.com
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=tu_cloudinary_cloud
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Database Configuration
# Use DB_TARGET=local while developing to avoid touching production data.
# Drizzle scripts use the same DB_TARGET switch.
DB_TARGET=testing
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/caliodb?sslmode=require
TEST_DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/caliodb_local
JWT_SECRET=replace-with-a-long-random-secret

# Contact Information (Honduras phone format: 504 area code)
CONTACT_PHONE=504XXXXXXXX

# Location Information - San Pedro Sula, Honduras
NEXT_PUBLIC_STREET_ADDRESS=San Pedro Sula, Honduras
NEXT_PUBLIC_POSTAL_CODE=22222
